#!/usr/bin/env python3
"""StillMirror MCP server — a thin, read-mostly adapter over the CLI.

For reflective, non-coding review in Claude Desktop. It surfaces *evidence*
(review-due, the alignment review) and records the *user's own* alignment
attestation. It never fabricates a review or renders a verdict — the judgment
stays the human's, and the alignment record names the human who is accountable.

Hand-rolled JSON-RPC 2.0 over newline-delimited stdio, stdlib only (no SDK), so
it keeps the project's zero-dependency identity. All real work is delegated to
the sibling `stillmirror-review` CLI.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any


CLI = str(Path(__file__).resolve().parent / "stillmirror-review")
SERVER_NAME = "stillmirror-review"
SERVER_VERSION = "0.5.0"
PROTOCOL_VERSION = "2024-11-05"

TOOLS = [
    {
        "name": "review_due",
        "description": (
            "What needs the user's review in a project: unreviewed allocations, new "
            "goal events, top-level sessions and distinct subagents since the last "
            "human-attested review, plus whether a drafted attestation is awaiting the "
            "user's ratification. Read-only evidence."
        ),
        "inputSchema": {
            "type": "object",
            "properties": {"project_path": {"type": "string", "description": "Absolute path to the project repository"}},
            "required": ["project_path"],
        },
    },
    {
        "name": "review",
        "description": (
            "Generate and return the project's Project Alignment Review (coverage and "
            "blind spots, review debt, goal provenance, triage, allocation evidence). "
            "This is evidence for the user's own review, NOT a verdict — present it as "
            "evidence and let the user judge; do not summarize it as a conclusion about "
            "whether the project is good or drifting."
        ),
        "inputSchema": {
            "type": "object",
            "properties": {
                "project_path": {"type": "string", "description": "Absolute path to the project repository"},
                "since": {"type": "string", "description": "Window, e.g. 30d (default 30d)"},
            },
            "required": ["project_path"],
        },
    },
    {
        "name": "record_alignment",
        "description": (
            "Record the USER'S OWN alignment attestation — the irreducible human act this "
            "tool exists to protect. You (the assistant) must NOT choose the labels or "
            "fabricate this judgment: pass only the labels the user explicitly chose, and "
            "name the user as the attester. Valid labels: necessary_support, "
            "intentional_pivot, operational_drift, exploration, noise, misclassification, "
            "insufficient_evidence."
        ),
        "inputSchema": {
            "type": "object",
            "properties": {
                "project_path": {"type": "string", "description": "Absolute path to the project repository"},
                "labels": {"type": "array", "items": {"type": "string"}, "description": "The labels the user chose"},
                "attested_by": {"type": "string", "description": "The user's name — who is accountable for this judgment"},
                "note": {"type": "string", "description": "The user's note, in their words"},
            },
            "required": ["project_path", "labels", "attested_by"],
        },
    },
    {
        "name": "propose_alignment",
        "description": (
            "DRAFT an alignment attestation for the user to ratify — assistance, NOT the "
            "judgment. Read the review evidence, propose labels + a plain-language note; "
            "the draft is recorded but does NOT count as an attestation (the seat stays "
            "empty until the user ratifies). Then present the user a one-line plain read "
            "and ask: does this look right, is something off, or can't you tell? — do NOT "
            "show them the label taxonomy; the labels are your machine-facing draft. Valid "
            "labels: necessary_support, intentional_pivot, operational_drift, exploration, "
            "noise, misclassification, insufficient_evidence."
        ),
        "inputSchema": {
            "type": "object",
            "properties": {
                "project_path": {"type": "string", "description": "Absolute path to the project repository"},
                "labels": {"type": "array", "items": {"type": "string"}, "description": "Your drafted labels"},
                "note": {"type": "string", "description": "Your drafted plain-language reasoning"},
                "drafted_by": {"type": "string", "description": "Who drafted this (e.g. 'assistant') — a draft is not an attestation"},
            },
            "required": ["project_path", "labels", "drafted_by"],
        },
    },
    {
        "name": "ratify_alignment",
        "description": (
            "Record the USER'S ratification of a drafted proposal — accept / amend / "
            "reject. This is the irreducible human act: only the user decides. accept = "
            "the user endorses your draft as-is; amend = the user changes labels/note; "
            "reject = the user won't endorse it and the seat stays empty. Pass the user's "
            "own decision and name them — never ratify on their behalf."
        ),
        "inputSchema": {
            "type": "object",
            "properties": {
                "project_path": {"type": "string", "description": "Absolute path to the project repository"},
                "decision": {"type": "string", "enum": ["accept", "amend", "reject"], "description": "The user's decision"},
                "attested_by": {"type": "string", "description": "The user's name — who ratifies"},
                "labels": {"type": "array", "items": {"type": "string"}, "description": "Override labels (amend only)"},
                "note": {"type": "string", "description": "Override note (amend only)"},
                "proposal_id": {"type": "string", "description": "Which pending proposal (default: the latest)"},
            },
            "required": ["project_path", "decision", "attested_by"],
        },
    },
]


def run_cli(project_path: str, args: list[str]) -> str:
    proc = subprocess.run(
        [sys.executable, CLI, *args],
        cwd=project_path or os.getcwd(),
        capture_output=True,
        text=True,
        encoding="utf-8",
        errors="replace",
        timeout=60,
    )
    if proc.returncode != 0:
        return f"error: {(proc.stderr or proc.stdout).strip()}"
    return proc.stdout.strip()


def call_tool(name: str, args: dict[str, Any]) -> str:
    project_path = args.get("project_path") or os.getcwd()
    if name == "review_due":
        return run_cli(project_path, ["review-due"])
    if name == "review":
        since = args.get("since") or "30d"
        out = run_cli(project_path, ["review", "--since", since])
        try:
            path = json.loads(out).get("output")
        except Exception:
            return out
        return Path(path).read_text(encoding="utf-8") if path else out
    if name == "record_alignment":
        labels = args.get("labels") or []
        attested_by = (args.get("attested_by") or "").strip()
        if not labels:
            return "error: at least one label is required — this must be the user's own choice."
        if not attested_by:
            return "error: attested_by is required — name the human who is accountable; do not attest on their behalf."
        cli_args = ["alignment", "record", "--attested-by", attested_by]
        for label in labels:
            cli_args += ["--label", str(label)]
        if args.get("note"):
            cli_args += ["--note", str(args["note"])]
        return run_cli(project_path, cli_args)
    if name == "propose_alignment":
        labels = args.get("labels") or []
        drafted_by = (args.get("drafted_by") or "").strip()
        if not labels:
            return "error: at least one drafted label is required."
        if not drafted_by:
            return "error: drafted_by is required — name who drafted this; a draft is not an attestation."
        cli_args = ["alignment", "propose", "--drafted-by", drafted_by]
        for label in labels:
            cli_args += ["--label", str(label)]
        if args.get("note"):
            cli_args += ["--note", str(args["note"])]
        return run_cli(project_path, cli_args)
    if name == "ratify_alignment":
        decision = (args.get("decision") or "").strip()
        attested_by = (args.get("attested_by") or "").strip()
        if decision not in ("accept", "amend", "reject"):
            return "error: decision must be accept, amend, or reject — the user's own choice."
        if not attested_by:
            return "error: attested_by is required — name the human ratifying; do not ratify on their behalf."
        cli_args = ["alignment", "ratify", "--decision", decision, "--attested-by", attested_by]
        if args.get("proposal_id"):
            cli_args += ["--proposal-id", str(args["proposal_id"])]
        for label in (args.get("labels") or []):
            cli_args += ["--label", str(label)]
        if args.get("note"):
            cli_args += ["--note", str(args["note"])]
        return run_cli(project_path, cli_args)
    return f"error: unknown tool {name}"


def handle(message: dict[str, Any]) -> dict[str, Any] | None:
    method = message.get("method")
    mid = message.get("id")
    if method == "initialize":
        return {
            "jsonrpc": "2.0",
            "id": mid,
            "result": {
                "protocolVersion": PROTOCOL_VERSION,
                "capabilities": {"tools": {}},
                "serverInfo": {"name": SERVER_NAME, "version": SERVER_VERSION},
            },
        }
    if method == "notifications/initialized":
        return None
    if method == "ping":
        return {"jsonrpc": "2.0", "id": mid, "result": {}}
    if method == "tools/list":
        return {"jsonrpc": "2.0", "id": mid, "result": {"tools": TOOLS}}
    if method == "tools/call":
        params = message.get("params") or {}
        try:
            text = call_tool(str(params.get("name")), params.get("arguments") or {})
            is_error = text.startswith("error:")
        except Exception as exc:  # never crash the server on one bad call
            text, is_error = f"error: {exc}", True
        return {"jsonrpc": "2.0", "id": mid, "result": {"content": [{"type": "text", "text": text}], "isError": is_error}}
    if mid is not None:
        return {"jsonrpc": "2.0", "id": mid, "error": {"code": -32601, "message": f"method not found: {method}"}}
    return None


def main() -> int:
    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue
        try:
            message = json.loads(line)
        except json.JSONDecodeError:
            continue
        if not isinstance(message, dict):
            continue
        response = handle(message)
        if response is not None:
            sys.stdout.write(json.dumps(response, ensure_ascii=False) + "\n")
            sys.stdout.flush()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
