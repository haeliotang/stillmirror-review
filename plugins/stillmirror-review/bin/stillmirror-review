    "build": "infra",
    "chore": "infra",
    "style": "infra",
    "revert": "triage_responding",
}


# Changed-file -> maintainer label. The path is "what actually changed" — more
# truthful than the subject's claim, and agnostic to whoever (human or agent)
# wrote the message. Only NON-code categories classify reliably from paths;
# code files return "" so the subject still decides feature-vs-fix.
FILE_RULES: list[tuple[str, str]] = [
    (r"(^|/)(tests?|spec|__tests__)/", "infra"),
    (r"(_test\.|\.test\.|_spec\.|\.spec\.)", "infra"),
    (r"(^|/)\.github/", "infra"),
    (r"(^|/)(dockerfile|docker-compose[^/]*|makefile|justfile)$", "infra"),
    (r"(^|/)(requirements[^/]*\.txt|package(-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|pyproject\.toml|setup\.(py|cfg)|go\.(mod|sum)|cargo\.(toml|lock)|gemfile)$", "infra"),
    (r"\.(ya?ml|toml|ini|cfg)$", "infra"),
    (r"(^|/)(changelog|history)", "release_packaging"),
    (r"(^|/)(readme|contributing|authors|code_of_conduct|license)", "docs"),
    (r"(^|/)docs?/", "docs"),
    (r"\.(md|rst|adoc)$", "docs"),
]


def file_label(path: str) -> str:
    text = path.casefold()
    for pattern, label in FILE_RULES:
        if re.search(pattern, text):
            return label
    return ""


def utc_now() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z")


def project_root() -> Path:
    return Path(os.getcwd()).resolve()


def sm_dir(root: Path) -> Path:
    return root / ".stillmirror"


def write_if_missing(path: Path, value: Any) -> bool:
    if path.exists():
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(value, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return True


def init_project(root: Path, quiet: bool = False) -> None:
    base = sm_dir(root)
    for name in [
        "traces/claude-code",
        "runs",
        "problems",
        "goals",
        "allocations",
        "alignment",
        "evidence",
        "snapshots",
        "reviews",
    ]:
        (base / name).mkdir(parents=True, exist_ok=True)
    write_if_missing(
        base / "problems" / "mainline-hypothesis.json",
        {
            "schema_version": 1,
            "statement": "",
            "confidence": 0.0,
            "alternatives": [],
            "evidence": [],
            "review_state": "unreviewed",
        },
    )
    write_if_missing(
        base / "goals" / "accepted-goals.json",
        {
            "schema_version": 1,
            "goals": [],
            "boundary": "AcceptedGoal means reviewed or accepted in this project context, not a true value function.",
        },
    )
    write_if_missing(
        base / "allocations" / "rubric.json",
        {"schema_version": 1, "rubric": RUBRIC},
    )
    readme = base / "README.md"
    if not readme.exists():
        readme.write_text(
            "# .stillmirror\n\n"
            "Local StillMirror Review state. Do not commit private traces unless explicitly redacted.\n",
            encoding="utf-8",
        )
    if not quiet:
        print(json.dumps({"initialized": str(base)}, ensure_ascii=False, indent=2))


def parse_since(value: str) -> dt.datetime:
    now = dt.datetime.now(dt.timezone.utc)
    match = re.fullmatch(r"(\d+)d", value.strip())
    if match:
        return now - dt.timedelta(days=int(match.group(1)))
    parsed = dt.datetime.fromisoformat(value.replace("Z", "+00:00"))
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    return parsed.astimezone(dt.timezone.utc)


def parse_time(value: str | None) -> dt.datetime | None:
    if not value:
        return None
    try:
        return dt.datetime.fromisoformat(value.replace("Z", "+00:00")).astimezone(dt.timezone.utc)
    except ValueError:
        return None


def load_json(path: Path, default: Any) -> Any:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return default


def write_json(path: Path, value: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(value, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def short_hash(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8", errors="replace")).hexdigest()[:12]


def slug(text: str) -> str:
    cleaned = re.sub(r"[^a-zA-Z0-9]+", "-", text.strip().lower()).strip("-")
    return cleaned[:48] or "goal"


def accepted_goals_path(root: Path) -> Path:
    return sm_dir(root) / "goals" / "accepted-goals.json"


def goal_events_path(root: Path) -> Path:
    return sm_dir(root) / "goals" / "goal-events.jsonl"


GOAL_EVENT_TYPES = {
    "goal_introduced",
    "goal_reinforced",
    "goal_replaced",
    "goal_retired",
}


def append_goal_event(
    root: Path,
    event_type: str,
    goal_id: str,
    statement: str,
    source: str = "user",
    note: str = "",
    supersedes: str = "",
) -> dict[str, Any]:
    """Append a goal-lifecycle event. This log is provenance, not state:

    accepted-goals.json holds the *current* projection; this log holds *how it
    got there* (introduced / reinforced / replaced / retired).
    """
    record: dict[str, Any] = {
        "schema_version": 1,
        "recorded_at": utc_now(),
        "type": event_type,
        "goal_id": goal_id,
        "statement": statement,
        "source": source,
        "note": note,
    }
    if supersedes:
        record["supersedes"] = supersedes
    record["event_id"] = short_hash(json.dumps(record, sort_keys=True, ensure_ascii=False))
    path = goal_events_path(root)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n")
    return record


def list_goal_events(root: Path) -> list[dict[str, Any]]:
    path = goal_events_path(root)
    if not path.exists():
        return []
    events = []
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            value = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(value, dict):
            events.append(value)
    return events


def resolve_goal(doc: dict[str, Any], ref: str) -> dict[str, Any] | None:
    """Resolve a goal by exact id, unique id substring, or exact statement."""
    goals = doc.get("goals") or []
    for goal in goals:
        if goal.get("id") == ref:
            return goal
    matches = [goal for goal in goals if ref and ref in str(goal.get("id") or "")]
    if len(matches) == 1:
        return matches[0]
    statement_matches = [goal for goal in goals if str(goal.get("statement") or "").strip() == ref.strip()]
    if len(statement_matches) == 1:
        return statement_matches[0]
    return None


def load_accepted_goals(root: Path) -> dict[str, Any]:
    init_project(root, quiet=True)
    doc = load_json(accepted_goals_path(root), {"schema_version": 1, "goals": []})
    if not isinstance(doc, dict):
        doc = {"schema_version": 1, "goals": []}
    if not isinstance(doc.get("goals"), list):
        doc["goals"] = []
    doc.setdefault(
        "boundary",
        "AcceptedGoal means reviewed or accepted in this project context, not a true value function.",
    )
    return doc


def add_goal(root: Path, statement: str, source: str, scope: str, review_state: str) -> dict[str, Any]:
    if not statement.strip():
        raise SystemExit("goal statement cannot be empty")
    doc = load_accepted_goals(root)
    goal_id = f"goal-{slug(statement)}-{short_hash(statement)}"
    existing = [goal for goal in doc["goals"] if goal.get("id") == goal_id]
    now = utc_now()
    record = {
        "id": goal_id,
        "statement": statement.strip(),
        "source": source,
        "scope": scope,
        "review_state": review_state,
        "created_at": now,
        "updated_at": now,
        "superseded": False,
        "retired": False,
    }
    if existing:
        existing[0].update({**record, "created_at": existing[0].get("created_at") or now})
        saved = existing[0]
        # Re-accepting a goal already in the project reinforces it.
        append_goal_event(root, "goal_reinforced", goal_id, saved["statement"], source=source)
    else:
        doc["goals"].append(record)
        saved = record
        append_goal_event(root, "goal_introduced", goal_id, saved["statement"], source=source)
    write_json(accepted_goals_path(root), doc)
    return saved


def retire_goal(root: Path, ref: str, note: str = "") -> dict[str, Any]:
    doc = load_accepted_goals(root)
    goal = resolve_goal(doc, ref)
    if goal is None:
        raise SystemExit(f"no unique goal matched: {ref!r}")
    goal["retired"] = True
    goal["updated_at"] = utc_now()
    write_json(accepted_goals_path(root), doc)
    append_goal_event(root, "goal_retired", str(goal.get("id") or ""), str(goal.get("statement") or ""), note=note)
    return goal


def replace_goal(
    root: Path,
    ref: str,
    new_statement: str,
    source: str,
    scope: str,
    review_state: str,
    note: str = "",
) -> dict[str, Any]:
    if not new_statement.strip():
        raise SystemExit("replacement goal statement cannot be empty")
    doc = load_accepted_goals(root)
    old = resolve_goal(doc, ref)
    if old is None:
        raise SystemExit(f"no unique goal matched: {ref!r}")
    old_id = str(old.get("id") or "")
    new_id = f"goal-{slug(new_statement)}-{short_hash(new_statement)}"
    now = utc_now()
    new_goal = {
        "id": new_id,
        "statement": new_statement.strip(),
        "source": source,
        "scope": scope,
        "review_state": review_state,
        "created_at": now,
        "updated_at": now,
        "superseded": False,
        "retired": False,
    }
    existing_new = [goal for goal in doc["goals"] if goal.get("id") == new_id]
    if existing_new:
        existing_new[0].update({**new_goal, "created_at": existing_new[0].get("created_at") or now})
        saved_new = existing_new[0]
    else:
        doc["goals"].append(new_goal)
        saved_new = new_goal
    old["superseded"] = True
    old["superseded_by"] = new_id
    old["updated_at"] = now
    write_json(accepted_goals_path(root), doc)
    append_goal_event(root, "goal_replaced", new_id, saved_new["statement"], source=source, note=note, supersedes=old_id)
    return {"old": old, "new": saved_new}


def set_problem(root: Path, statement: str, confidence: float, alternatives: list[str]) -> dict[str, Any]:
    init_project(root, quiet=True)
    path = sm_dir(root) / "problems" / "mainline-hypothesis.json"
    doc = load_json(path, {})
    if not isinstance(doc, dict):
        doc = {}
    doc.update(
        {
            "schema_version": 1,
            "statement": statement.strip(),
            "confidence": max(0.0, min(1.0, confidence)),
            "alternatives": alternatives or [],
            "review_state": "reviewed",
            "updated_at": utc_now(),
        }
    )
    doc.setdefault("evidence", [])
    write_json(path, doc)
    return doc


def list_goals(root: Path) -> dict[str, Any]:
    return load_accepted_goals(root)


ALIGNMENT_LABELS = {
    "necessary_support",
    "intentional_pivot",
    "operational_drift",
    "exploration",
    "noise",
    "misclassification",
    "insufficient_evidence",
}


def alignment_path(root: Path) -> Path:
    return sm_dir(root) / "alignment" / "alignment-reviews.jsonl"


def default_attester(root: Path) -> str:
    try:
        name = subprocess.run(
            ["git", "-C", str(root), "config", "user.name"],
            capture_output=True, text=True, encoding="utf-8", errors="replace", timeout=5,
        ).stdout.strip()
        if name:
            return name
    except Exception:
        pass
    return os.environ.get("USER") or os.environ.get("USERNAME") or "unknown"


def record_alignment(root: Path, labels: list[str], note: str, review_file: str, attested_by: str = "") -> dict[str, Any]:
    init_project(root, quiet=True)
    bad = sorted(set(labels) - ALIGNMENT_LABELS)
    if bad:
        raise SystemExit(f"unknown alignment labels: {', '.join(bad)}")
    if not labels:
        raise SystemExit("at least one alignment label is required")
    review_ref = ""
    if review_file:
        try:
            review_ref = str(Path(review_file).expanduser().resolve().relative_to(root.resolve()))
        except Exception:
            review_ref = str(Path(review_file).expanduser())
    ledger_file = sm_dir(root) / "allocations" / "allocation-ledger.json"
    ledger = load_json(ledger_file, {})
    # An alignment record is the irreducible human act this whole tool exists to
    # protect: a named person standing behind a judgment. It must not be
    # ghost-written by an agent — the attester names who is accountable.
    record = {
        "schema_version": 1,
        "recorded_at": utc_now(),
        "labels": labels,
        "note": note,
        "review_file": review_ref,
        "attested_by": attested_by.strip() or default_attester(root),
        "human_attested": True,
        "ledger_generated_at": ledger.get("generated_at") if isinstance(ledger, dict) else None,
        "ledger_entry_count": ledger.get("entry_count") if isinstance(ledger, dict) else None,
    }
    path = alignment_path(root)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n")
    return record


def list_alignment(root: Path) -> list[dict[str, Any]]:
    path = alignment_path(root)
    if not path.exists():
        return []
    records = []
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            value = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(value, dict):
            records.append(value)
    return records


def last_attestation(root: Path) -> dict[str, Any] | None:
    """The most recent alignment record — the last time a human stood behind a review."""
    records = list_alignment(root)
    attested = [record for record in records if record.get("human_attested")]
    chosen = attested or records
    return chosen[-1] if chosen else None


def event_text(event: dict[str, Any]) -> str:
    pieces = [
        str(event.get("hook_event_name") or ""),
        str(event.get("tool_name") or ""),
    ]
    summary = event.get("tool_input_summary")
    if isinstance(summary, dict):
        pieces.extend(str(value) for value in summary.get("keys") or [])
        # Use only the file name, not the full path. Directory segments
        # (and the project's own name) would otherwise inject rubric
        # keywords into every event and pollute the classification.
        pieces.extend(Path(str(value)).name for value in summary.get("paths") or [])
        if isinstance(summary.get("command"), dict):
            pieces.append(str(summary["command"].get("first_token") or ""))
        if isinstance(summary.get("description"), dict):
            pieces.append(str(summary["description"].get("preview") or ""))
    if isinstance(event.get("prompt"), dict):
        pieces.append(str(event["prompt"].get("preview") or ""))
    return " ".join(pieces).casefold()


def token_match(pattern: str, text: str) -> bool:
    """Match a rubric pattern at a word boundary, not as a raw substring.

    Word-boundary matching keeps inflections (``hook`` -> ``hooks``) while
    avoiding mid-word false positives (``test`` inside ``latest``, ``fix``
    inside ``prefix``).
    """
    return re.search(r"\b" + re.escape(pattern), text) is not None


def word_match(pattern: str, text: str) -> bool:
    """Whole-word match (both boundaries) for short commit-subject keywords.

    Commit subjects are short, so precision matters: ``add`` must not match
    ``address`` and ``doc`` must not match ``docker``. Inflections are listed
    explicitly in MAINTAINER_PROFILE instead of relying on prefix matching.
    """
    return re.search(r"\b" + re.escape(pattern) + r"\b", text) is not None


def classify(
    text: str,
    accepted_goals: list[dict[str, Any]],
    hook_event_name: str = "",
) -> dict[str, Any]:
    """Classify one event into rubric labels and return a self-describing receipt.

    The returned dict carries not just the labels but *why* they were assigned
    (which rubric patterns and which goal tokens matched), so a downstream
    reviewer can audit the classification instead of trusting it blind.
    """
    # Lifecycle/control events carry no allocation signal; label them as
    # noise instead of letting them default into exploration.
    if hook_event_name in LIFECYCLE_EVENTS:
        return {
            "labels": ["noise"],
            "related_goal": "",
            "supports_mainline": "unknown",
            "confidence": 0.6,
            "ambiguity": [],
            "matched_patterns": {},
            "goal_signals": [],
            "reason": "lifecycle_event",
        }
    matched_patterns: dict[str, list[str]] = {}
    for label, spec in RUBRIC.items():
        if label in ("core_problem", "noise"):
            continue
        hits = [pattern for pattern in (spec.get("patterns") or []) if token_match(pattern, text)]
        if hits:
            matched_patterns[label] = hits
    labels = list(matched_patterns.keys())
    related_goal = ""
    goal_signals: list[dict[str, Any]] = []
    for goal in accepted_goals:
        statement = str(goal.get("statement") or goal.get("goal") or "").strip()
        if not statement:
            continue
        tokens = [token for token in re.split(r"[^a-zA-Z0-9_]+", statement.casefold()) if len(token) >= 4]
        hits = sorted({token for token in tokens if token_match(token, text)})
        if hits:
            goal_signals.append({"goal_id": str(goal.get("id") or ""), "statement": statement, "tokens": hits})
    if goal_signals:
        labels.insert(0, "core_problem")
        related_goal = goal_signals[0]["statement"]
        supports_mainline = "yes"
    else:
        supports_mainline = "unknown"
    if not labels:
        labels = ["exploration"]
        confidence = 0.35
        ambiguity = ["no rubric or goal signal; defaulted to exploration"]
    else:
        # A single clean match is the most confident outcome; each extra
        # label means more ambiguity, so confidence decreases, not increases.
        count = len(labels)
        confidence = 0.7 if count == 1 else max(0.4, 0.75 - 0.1 * (count - 1))
        ambiguity = ["multiple rubric labels matched"] if count > 1 else []
    # Stable order and dedupe.
    labels = [label for label in RUBRIC if label in set(labels)]
    return {
        "labels": labels,
        "related_goal": related_goal,
        "supports_mainline": supports_mainline,
        "confidence": confidence,
        "ambiguity": ambiguity,
        "matched_patterns": matched_patterns,
        "goal_signals": goal_signals,
        "reason": "rubric_match" if matched_patterns or goal_signals else "default_exploration",
    }


def load_trace_events(root: Path, since: dt.datetime) -> list[dict[str, Any]]:
    trace_dir = sm_dir(root) / "traces" / "claude-code"
    events: list[dict[str, Any]] = []
    if not trace_dir.exists():
        return events
    for path in sorted(trace_dir.glob("*.jsonl")):
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
            if not line.strip():
                continue
            try:
                event = json.loads(line)
            except json.JSONDecodeError:
                continue
            captured = parse_time(event.get("captured_at"))
            if captured and captured >= since:
                events.append(event)
    return events


def git_entries(root: Path, since: dt.datetime, base_range: str = "") -> list[dict[str, Any]]:
    # With a base ref, scope to the exact commit range base..HEAD (precise for a
    # PR/branch); otherwise fall back to the time window.
    if base_range:
        selector = [f"{base_range}..HEAD"]
    else:
        selector = ["--since", since.isoformat()]
    try:
        raw = subprocess.run(
            ["git", "-C", str(root), "log", *selector, "--format=%H%x1f%at%x1f%s"],
            check=True,
            capture_output=True,
            text=True,
            encoding="utf-8",
            errors="replace",
            timeout=10,
        ).stdout
    except Exception:
        return []
    entries = []
    for line in raw.splitlines():
        fields = line.split("\x1f", 2)
        if len(fields) != 3:
            continue
        commit, timestamp, subject = fields
        when = dt.datetime.fromtimestamp(float(timestamp), tz=dt.timezone.utc)
        entries.append(
            {
                "schema_version": 1,
                "captured_at": when.isoformat().replace("+00:00", "Z"),
                "hook_event_name": "GitCommit",
                "tool_name": "git",
                "event_id": commit[:20],
                "tool_input_summary": {
                    "description": {"preview": subject, "chars": len(subject)},
                    "commit": commit,
                },
            }
        )
    return entries


def base_since_value(root: Path, base_ref: str) -> str | None:
    """Resolve the commit time of merge-base(base_ref, HEAD) as an ISO string.

    Used to scope a review to "this branch's work" for a PR-time trigger.
    """
    try:
        merge_base = subprocess.run(
            ["git", "-C", str(root), "merge-base", base_ref, "HEAD"],
            check=True, capture_output=True, text=True, encoding="utf-8", errors="replace", timeout=10,
        ).stdout.strip()
        if not merge_base:
            return None
        when = subprocess.run(
            ["git", "-C", str(root), "show", "-s", "--format=%cI", merge_base],
            check=True, capture_output=True, text=True, encoding="utf-8", errors="replace", timeout=10,
        ).stdout.strip()
        return when or None
    except Exception:
        return None


def last_reviewed_at(root: Path) -> dt.datetime | None:
    """Timestamp of the most recent recorded alignment review, if any."""
    times = [parse_time(record.get("recorded_at")) for record in list_alignment(root)]
    times = [value for value in times if value]
    return max(times) if times else None


def compute_review_due(root: Path, threshold: int) -> dict[str, Any]:
    """Derive whether a review is due, keyed to *human* boundaries, not agents.

    "New since your last review" aggregates across every session/agent thread,
    so one human return surfaces one number no matter how many agents ran.
    No persisted state: everything is derived from existing traces, goal events,
    and the last alignment record.
    """
    init_project(root, quiet=True)
    reference = last_reviewed_at(root)
    epoch = dt.datetime(1970, 1, 1, tzinfo=dt.timezone.utc)
    events = load_trace_events(root, reference or epoch)
    new_allocations = [
        event for event in events
        if str(event.get("hook_event_name") or "") not in LIFECYCLE_EVENTS
    ]
    sessions = {
        str(event.get("session_id_hash") or "")
        for event in new_allocations
        if event.get("session_id_hash")
    }
    goal_events = list_goal_events(root)
    if reference is not None:
        goal_events = [
            event for event in goal_events
            if (parse_time(event.get("recorded_at")) or epoch) > reference
        ]
    due = len(new_allocations) >= threshold or len(goal_events) > 0
    return {
        "due": due,
        "threshold": threshold,
        "last_reviewed_at": reference.isoformat().replace("+00:00", "Z") if reference else None,
        "new_allocations": len(new_allocations),
        "new_goal_events": len(goal_events),
        "sessions_touched": len(sessions),
    }


def nudge_threshold(explicit: int | None) -> int:
    if explicit is not None:
        return explicit
    try:
        return int(os.environ.get("STILLMIRROR_NUDGE_THRESHOLD", ""))
    except ValueError:
        return 20


def run_nudge(threshold: int) -> int:
    """SessionStart hook body: stay silent unless opted in AND a review is due.

    Triggers at a *human* boundary (a new session), aggregating all agent work
    accumulated since the last review into a single quiet line.
    """
    if os.environ.get("STILLMIRROR_SESSION_NUDGE") != "1":
        return 0
    try:
        raw = sys.stdin.read()
    except Exception:
        raw = ""
    root = project_root()
    try:
        payload = json.loads(raw) if raw.strip() else {}
        if isinstance(payload, dict) and payload.get("cwd"):
            root = Path(str(payload["cwd"])).expanduser().resolve()
    except Exception:
        pass
    try:
        status = compute_review_due(root, threshold)
    except Exception:
        return 0
    if not status["due"]:
        return 0
    message = (
        f"StillMirror: {status['new_allocations']} allocation(s) across "
        f"{status['sessions_touched']} session(s) and {status['new_goal_events']} "
        f"goal event(s) since your last review — run /stillmirror-review:review"
    )
    print(
        json.dumps(
            {"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": message}},
            ensure_ascii=False,
        )
    )
    return 0


def corrections_path(root: Path) -> Path:
    return sm_dir(root) / "allocations" / "corrections.jsonl"


def load_corrections(root: Path) -> dict[str, dict[str, Any]]:
    """Return the latest human correction per event_id (last write wins)."""
    path = corrections_path(root)
    if not path.exists():
        return {}
    result: dict[str, dict[str, Any]] = {}
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            record = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(record, dict) and record.get("event_id"):
            result[str(record["event_id"])] = record
    return result


def record_correction(root: Path, event_id: str, labels: list[str], note: str) -> dict[str, Any]:
    init_project(root, quiet=True)
    if not event_id.strip():
        raise SystemExit("an event_id is required")
    bad = sorted(set(labels) - set(RUBRIC.keys()))
    if bad:
        raise SystemExit(f"unknown rubric labels: {', '.join(bad)}")
    if not labels:
        raise SystemExit("at least one rubric label is required")
    record = {
        "schema_version": 1,
        "recorded_at": utc_now(),
        "event_id": event_id.strip(),
        "labels": [label for label in RUBRIC if label in set(labels)],
        "note": note,
    }
    path = corrections_path(root)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        handle.write(json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n")
    return record


def build_ledger(root: Path, since_value: str, base: str | None = None) -> dict[str, Any]:
    init_project(root, quiet=True)
    if base:
        resolved = base_since_value(root, base)
        since = parse_since(resolved) if resolved else parse_since(since_value)
    else:
        since = parse_since(since_value)
    goals_doc = load_json(sm_dir(root) / "goals" / "accepted-goals.json", {"goals": []})
    accepted_goals = goals_doc.get("goals") if isinstance(goals_doc, dict) else []
    if not isinstance(accepted_goals, list):
        accepted_goals = []
    corrections = load_corrections(root)
    events = load_trace_events(root, since)
    git_events = git_entries(root, since, base or "")
    events.extend(git_events)
    entries = []
    reinforcement: Counter[str] = Counter()
    for event in events:
        text = event_text(event)
        result = classify(text, accepted_goals, str(event.get("hook_event_name") or ""))
        event_id = str(event.get("event_id") or "unknown")
        auto_labels = result["labels"]
        review_state = "unreviewed"
        allocated_to = auto_labels
        correction = corrections.get(event_id)
        if correction:
            allocated_to = correction["labels"]
            review_state = "corrected"
        for signal in result["goal_signals"]:
            reinforcement[signal.get("goal_id") or signal.get("statement") or ""] += 1
        entry = {
            "schema_version": 1,
            "timestamp": event.get("captured_at") or utc_now(),
            "event_id": event_id,
            "session": str(event.get("session_id_hash") or ""),
            "source": event.get("hook_event_name") or "unknown",
            "resource_type": event.get("tool_name") or event.get("hook_event_name") or "unknown",
            "allocated_to": allocated_to,
            "related_goal": result["related_goal"],
            "supports_mainline": result["supports_mainline"],
            "confidence": round(result["confidence"], 2),
            "ambiguity": result["ambiguity"],
            "review_state": review_state,
            # The receipt is the evidence trail: why this label, from what.
            "receipt": {
                "event_id": event_id,
                "source_event": f"{event.get('hook_event_name') or 'unknown'}/{event.get('tool_name') or event.get('hook_event_name') or 'unknown'}",
                "reason": result["reason"],
                "matched_patterns": result["matched_patterns"],
                "goal_signals": result["goal_signals"],
                "auto_labels": auto_labels,
                "auto_confidence": round(result["confidence"], 2),
            },
        }
        if correction:
            entry["correction"] = {
                "labels": correction["labels"],
                "note": correction.get("note", ""),
                "recorded_at": correction.get("recorded_at"),
            }
        entries.append(entry)
    counts = Counter(label for entry in entries for label in entry["allocated_to"])
    # Coverage / blind-spot accounting: be loud about what we cannot see.
    trace_event_count = len(events) - len(git_events)
    git_commit_count = len(git_events)
    noise_entries = sum(1 for entry in entries if entry["allocated_to"] == ["noise"])
    corrected_entries = sum(1 for entry in entries if entry["review_state"] == "corrected")
    low_signal_entries = sum(
        1
        for entry in entries
        if entry["review_state"] != "corrected"
        and not entry["receipt"]["matched_patterns"]
        and not entry["receipt"]["goal_signals"]
        and entry["receipt"]["reason"] != "lifecycle_event"
    )
    low_confidence_entries = sum(
        1 for entry in entries if entry["review_state"] != "corrected" and entry["confidence"] < 0.5
    )
    coverage = {
        "trace_events": trace_event_count,
        "git_commits": git_commit_count,
        "noise_entries": noise_entries,
        "low_signal_entries": low_signal_entries,
        "low_confidence_entries": low_confidence_entries,
        "corrected_entries": corrected_entries,
        "not_captured": [
            "Decisions or reasoning that happened only in chat, not as tool calls.",
            "Work done outside Claude Code or outside this repository.",
            "The intent, effort, or impact behind any single event.",
        ],
    }
    if git_commit_count and trace_event_count == 0:
        coverage["note"] = (
            "Commits exist in this window but no Claude Code traces were captured; "
            "that work happened outside this tool's view."
        )
    ledger = {
        "schema_version": 1,
        "generated_at": utc_now(),
        "since": since.isoformat().replace("+00:00", "Z"),
        "rubric": list(RUBRIC.keys()),
        "entry_count": len(entries),
        "allocation_counts": dict(counts),
        "coverage": coverage,
        "goal_reinforcement": {key: value for key, value in reinforcement.items() if key},
        "entries": entries,
    }
    output = sm_dir(root) / "allocations" / "allocation-ledger.json"
    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text(json.dumps(ledger, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return ledger


def render_review(root: Path, since_value: str, base_ref: str | None = None) -> Path:
    ledger = build_ledger(root, since_value, base_ref)
    base = sm_dir(root)
    hypothesis = load_json(base / "problems" / "mainline-hypothesis.json", {})
    goals = load_json(base / "goals" / "accepted-goals.json", {"goals": []})
    goal_events = list_goal_events(root)
    counts = Counter(ledger.get("allocation_counts") or {})
    total = sum(counts.values()) or 1
    coverage = ledger.get("coverage") or {}
    reinforcement = ledger.get("goal_reinforcement") or {}
    accepted = goals.get("goals") if isinstance(goals, dict) else []

    lines = [
        "# StillMirror Project Alignment Review",
        "",
        f"- Generated: {ledger['generated_at']}",
        f"- Window start: {ledger['since']}",
        "",
        "This review joins two spines: the goals you accepted (what you authorized)",
        "and the allocation evidence (what the agent did). The labels are a rough",
        "prompt for your review, not a measurement or a verdict.",
        "",
        "## Coverage & Blind Spots",
        "",
        "StillMirror only sees Claude Code hook events and git commits in this",
        "repository. Read everything below as partial evidence.",
        "",
        f"- Trace events captured: {coverage.get('trace_events', 0)}",
        f"- Git commits in window: {coverage.get('git_commits', 0)}",
        f"- Lifecycle events set aside as `noise`: {coverage.get('noise_entries', 0)}",
        f"- Entries with no rubric or goal signal (could not classify): {coverage.get('low_signal_entries', 0)}",
        f"- Entries below 0.5 confidence: {coverage.get('low_confidence_entries', 0)}",
        f"- Human-corrected entries: {coverage.get('corrected_entries', 0)}",
        "",
        "Not captured by StillMirror:",
    ]
    for item in coverage.get("not_captured") or []:
        lines.append(f"- {item}")
    if coverage.get("note"):
        lines.extend(["", f"> {coverage['note']}"])

    # Review debt: agent work authorized but not yet stood behind. The scarce
    # budget is human attention; this is the overspend, measured against the last
    # *human-attested* review (not the last automated anything).
    debt = compute_review_due(root, nudge_threshold(None))
    last_att = last_attestation(root)
    if last_att:
        attested_line = (
            f"- Last attested review: {str(last_att.get('recorded_at', ''))[:10]} "
            f"by {last_att.get('attested_by') or 'unknown'}"
        )
    else:
        attested_line = "- Last attested review: (none yet — nothing has been stood behind)"
    lines.extend(
        [
            "",
            "## Review Debt",
            "",
            "Agent work you authorized but have not yet stood behind. The budget here",
            "is your attention; this is the overspend.",
            "",
            attested_line,
            f"- Unreviewed allocations since: {debt['new_allocations']}",
            f"- New goal events since: {debt['new_goal_events']}",
            f"- Agent threads (sessions) since: {debt['sessions_touched']}",
        ]
    )

    lines.extend(
        [
            "",
            "## Mainline Hypothesis",
            "",
            f"- Statement: {hypothesis.get('statement') or '(unreviewed)'}",
            f"- Confidence: {hypothesis.get('confidence', 0)}",
            f"- Alternatives: {', '.join(hypothesis.get('alternatives') or []) or '(none recorded)'}",
            "",
            "## Goal Provenance",
            "",
        ]
    )
    if accepted:
        for goal in accepted:
            state = "retired" if goal.get("retired") else ("superseded" if goal.get("superseded") else "active")
            hits = reinforcement.get(str(goal.get("id") or ""), 0)
            lines.append(
                f"- {goal.get('statement') or goal.get('goal')} "
                f"— {state}, reinforced by {hits} allocation(s)"
            )
    else:
        lines.extend(
            [
                "- (no accepted goals recorded yet)",
                "",
                "> No accepted goals are recorded, so no allocation can be matched to",
                "> `core_problem`. Add goals first to enable core-problem detection:",
                ">",
                "> ```sh",
                '> stillmirror-review goals add "<your goal>"',
                "> ```",
            ]
        )
    if goal_events:
        lines.extend(["", "Recent goal events:"])
        for event in goal_events[-5:]:
            lines.append(f"- {event.get('recorded_at', '')[:10]} `{event.get('type')}` — {event.get('statement')}")

    # Triage: where to spend scarce human attention across a flood of agent work.
    # Aggregate to navigate (clusters + surfaced exceptions), never to judge.
    entries = ledger.get("entries") or []
    reference = last_reviewed_at(root)
    epoch = dt.datetime(1970, 1, 1, tzinfo=dt.timezone.utc)
    unlinked = [
        entry for entry in entries
        if entry["allocated_to"] != ["noise"] and not entry["receipt"]["goal_signals"]
    ]
    if reference is not None:
        new_since = [entry for entry in entries if (parse_time(entry.get("timestamp")) or epoch) > reference]
    else:
        new_since = [entry for entry in entries if entry["allocated_to"] != ["noise"]]
    by_session: dict[str, Counter] = {}
    for entry in entries:
        key = entry.get("session") or "(non-session: git/other)"
        by_session.setdefault(key, Counter())
        for label in entry["allocated_to"]:
            by_session[key][label] += 1

    lines.extend(
        [
            "",
            "## Triage — what's worth your attention",
            "",
            "Pointers for where to spend review attention, not judgments. Surfaced ≠",
            "judged wrong; not surfaced ≠ approved. Every item is auditable by its",
            "`event_id` in the ledger.",
            "",
            "By problem (allocations linked to each accepted goal):",
        ]
    )
    if accepted:
        for goal in accepted:
            hits = reinforcement.get(str(goal.get("id") or ""), 0)
            lines.append(f"- {goal.get('statement') or goal.get('goal')}: {hits}")
    else:
        lines.append("- (no accepted goals to link against)")
    lines.append(f"- unlinked (no goal signal): {len(unlinked)}  ← work not tied to any accepted goal")
    lines.extend(
        [
            "",
            "By session / agent thread (which problems each thread served — coverage, not a ranking):",
        ]
    )
    if by_session:
        for key in sorted(by_session):
            mix = ", ".join(f"{label}:{count}" for label, count in by_session[key].most_common())
            short = key[:8] if key and not key.startswith("(") else key
            lines.append(f"- session {short}: {mix}")
    else:
        lines.append("- (no sessions in window)")
    lines.extend(["", "Surfaced for review:"])
    if unlinked:
        ids = ", ".join(entry["event_id"] for entry in unlinked[:8])
        more = "" if len(unlinked) <= 8 else f" (+{len(unlinked) - 8} more)"
        lines.append(f"- {len(unlinked)} allocation(s) not linked to any accepted goal — event_ids: {ids}{more}")
    if reference is not None:
        lines.append(
            f"- {len(new_since)} allocation(s) new since your last review "
            f"({reference.isoformat().replace('+00:00', 'Z')[:10]})"
        )
    else:
        lines.append(f"- no prior review recorded; treat all {len(new_since)} non-noise allocation(s) as unreviewed")
    low_signal = coverage.get("low_signal_entries", 0)
    if low_signal:
        lines.append(f"- {low_signal} entry(ies) could not be classified (no rubric or goal signal)")
    if coverage.get("note"):
        lines.append(f"- {coverage['note']}")

    lines.extend(
        [
            "",
            "## Allocation Ledger Summary",
            "",
            "_Percentages are the share of all label assignments, not of entries; a"
            " single entry may carry multiple labels._",
            "",
        ]
    )
    for label in RUBRIC:
        count = counts.get(label, 0)
        pct = round(count * 100 / total)
        lines.append(f"- `{label}`: {count} ({pct}%)")
    lines.extend(
        [
            "",
            "## Observed Divergence",
            "",
            "This section is an evidence question, not a system judgment.",
            "",
        ]
    )
    core = counts.get("core_problem", 0)
    if ledger.get("entry_count", 0) == 0:
        lines.append("- No allocation entries were observed in this window.")
    elif not accepted:
        lines.append("- `core_problem` cannot be evaluated because no accepted goals are recorded; add goals and regenerate this review.")
    elif core == 0:
        lines.append("- No entries were classified as `core_problem`; review whether this is missing context, necessary support, exploration, or misclassification.")
    else:
        lines.append("- Some entries matched `core_problem`; review whether the surrounding support allocations are appropriate.")
    lines.extend(
        [
            "",
            "## Alignment Review",
            "",
            "Choose one or more labels:",
            "",
            "- necessary_support",
            "- intentional_pivot",
            "- operational_drift",
            "- exploration",
            "- noise",
            "- misclassification",
            "- insufficient_evidence",
            "",
            "If a label looks wrong, correct the underlying entry so future reviews",
            "honor your judgment:",
            "",
            "```sh",
            'stillmirror-review correct --event <event_id> --label <rubric_label>',
            "```",
            "",
            "## Boundaries",
            "",
            "- No drift score is produced.",
            "- No objective-capture diagnosis is produced.",
            "- Alignment is user review, not system verdict.",
            "",
        ]
    )
    output = base / "reviews" / f"{utc_now()[:10]}-project-alignment-review.md"
    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text("\n".join(lines), encoding="utf-8")
    return output


# Everything that is upkeep rather than advancing the core. `other` is excluded
# (kept honest, not force-fit). Used for the badge and the report line.
UPKEEP_LABELS = ("bug_fixing", "infra", "release_packaging", "docs", "triage_responding")


# A bot authoring a change is not, by itself, accountable in the deep sense — a
# human explicitly standing behind a change is. We surface this as evidence about
# accountability coverage, never as a ranking or score of any contributor.
KNOWN_BOT_NAMES = {
    "dependabot", "dependabot[bot]", "github-actions", "github-actions[bot]",
    "renovate", "renovate[bot]", "mergify", "mergify[bot]", "greenkeeper",
    "greenkeeperio-bot", "codecov", "snyk-bot", "imgbot", "pre-commit-ci[bot]",
    "allcontributors[bot]", "weblate",
}


def author_is_bot(name: str, email: str) -> bool:
    lname, lemail = name.casefold(), email.casefold()
    if "[bot]" in lname or "[bot]" in lemail:
        return True
    if lname in KNOWN_BOT_NAMES:
        return True
    return lemail.split("@", 1)[0] in KNOWN_BOT_NAMES


def attestation_tier(name: str, email: str, signature: str, signoff: str) -> str:
    """Classify a commit's accountability: bot | attested | human.

    ``attested`` = a human who left an explicit accountability marker (a
    Signed-off-by trailer or a cryptographic signature). ``human`` = a human
    author with only implicit attestation. ``bot`` = unaccountable by default.
    Signatures are *detected*, not verified (there are no public keys here).
    """
    if author_is_bot(name, email):
        return "bot"
    if signoff.strip() or signature not in ("", "N"):
        return "attested"
    return "human"


def git_commit_files(root: Path, since: dt.datetime, base_range: str = "") -> list[dict[str, Any]]:
    """Read commits with changed files and authorship/attestation (git-only, no merges)."""
    if base_range:
        selector = [f"{base_range}..HEAD"]
    else:
        selector = ["--since", since.isoformat()]
    fmt = "%x1e%H%x1f%s%x1f%an%x1f%ae%x1f%G?%x1f%(trailers:key=Signed-off-by,valueonly,separator=%x20)"
    try:
        raw = subprocess.run(
            ["git", "-C", str(root), "log", *selector, "--no-merges", "--no-renames", "--numstat", f"--format={fmt}"],
            check=True, capture_output=True, text=True, encoding="utf-8", errors="replace", timeout=15,
        ).stdout
    except Exception:
        return []
    commits = []
    for chunk in raw.split("\x1e"):
        if not chunk.strip():
            continue
        lines = chunk.split("\n")
        head = lines[0].split("\x1f")
        files: list[str] = []
        # Diffs are read (added+deleted lines per file) purely to classify mixed
        # commits more truthfully — never reported as a line count or LOC metric.
        weights: dict[str, int] = {}
        for line in lines[1:]:
            if not line.strip():
                continue
            parts = line.split("\t")
            if len(parts) < 3:
                continue
            added, deleted, path = parts[0], parts[1], parts[2]
            files.append(path)
            weights[path] = (int(added) if added.isdigit() else 0) + (int(deleted) if deleted.isdigit() else 0)
        commits.append(
            {
                "commit": head[0] if head else "",
                "subject": head[1] if len(head) > 1 else "",
                "author_name": head[2] if len(head) > 2 else "",
                "author_email": head[3] if len(head) > 3 else "",
                "signature": head[4] if len(head) > 4 else "",
                "signoff": head[5] if len(head) > 5 else "",
                "files": files,
                "file_weights": weights,
            }
        )
    return commits


def gh_pr_issue_activity(root: Path, since: dt.datetime) -> dict[str, Any] | None:
    """Optional PR/issue enrichment via the `gh` CLI. Returns None — degrade
    gracefully — when gh is missing, unauthenticated, or the repo is not on
    GitHub. The wedge stays git-only by default; this only fires on opt-in.
    """
    epoch = dt.datetime(1970, 1, 1, tzinfo=dt.timezone.utc)

    def gh_json(args: list[str]) -> Any:
        result = subprocess.run(
            ["gh", *args], cwd=str(root), capture_output=True, text=True,
            encoding="utf-8", errors="replace", timeout=20,
        )
        if result.returncode != 0:
            raise RuntimeError(result.stderr.strip() or "gh failed")
        return json.loads(result.stdout or "[]")

    try:
        prs = gh_json(["pr", "list", "--state", "merged", "--limit", "500", "--json", "mergedAt"])
        issues = gh_json(["issue", "list", "--state", "closed", "--limit", "500", "--json", "closedAt"])
        open_prs = gh_json(["pr", "list", "--state", "open", "--limit", "500", "--json", "number"])
        open_issues = gh_json(["issue", "list", "--state", "open", "--limit", "500", "--json", "number"])
    except Exception:
        return None
    merged = sum(1 for pr in prs if (parse_time(pr.get("mergedAt")) or epoch) >= since)
    closed = sum(1 for issue in issues if (parse_time(issue.get("closedAt")) or epoch) >= since)
    return {
        "merged_prs": merged,
        "closed_issues": closed,
        "open_prs": len(open_prs),
        "open_issues": len(open_issues),
    }


def classify_commit(subject: str, files: list[str] | None = None, file_weights: dict[str, int] | None = None) -> dict[str, Any]:
    """Classify a commit into a maintainer label + its canonical class.

    Priority: conventional-commit prefix (structured author intent) -> changed
    files (all agree on one non-code category) -> the *bulk of the diff* by
    changed lines when files span categories (diffs are read to classify, never
    reported as a line count) -> whole-word subject keywords -> other. ``other``
    stays honest: ambiguous code commits with vague subjects are not force-fit.
    """
    files = files or []
    text = subject.casefold()
    match = re.match(r"\s*([a-z]+)(\([^)]*\))?!?:", text)
    if match and match.group(1) in CONVENTIONAL_COMMIT:
        label = CONVENTIONAL_COMMIT[match.group(1)]
        return {"label": label, "canonical": MAINTAINER_PROFILE[label]["canonical"], "reason": f"conventional:{match.group(1)}"}
    file_labels = [file_label(path) for path in files]
    if file_labels and all(file_labels) and len(set(file_labels)) == 1:
        label = file_labels[0]
        return {"label": label, "canonical": MAINTAINER_PROFILE[label]["canonical"], "reason": "files"}
    # Mixed file categories: let the bulk of the actual change decide, when one
    # non-code category holds the majority of changed lines. The line counts are
    # used here and discarded — they are never surfaced as a metric.
    if file_weights:
        category_lines: dict[str, int] = {}
        total_lines = 0
        for path in files:
            label = file_label(path)
            weight = file_weights.get(path, 0)
            total_lines += weight
            if label:
                category_lines[label] = category_lines.get(label, 0) + weight
        if category_lines and total_lines > 0:
            top = max(category_lines, key=category_lines.get)
            if category_lines[top] / total_lines >= 0.6:
                return {"label": top, "canonical": MAINTAINER_PROFILE[top]["canonical"], "reason": "diff"}
    for label, spec in MAINTAINER_PROFILE.items():
        if label == "other":
            continue
        if any(word_match(pattern, text) for pattern in spec["patterns"]):
            return {"label": label, "canonical": spec["canonical"], "reason": "keyword"}
    return {"label": "other", "canonical": MAINTAINER_PROFILE["other"]["canonical"], "reason": "no_match"}


def shields_badge_url(label: str, message: str, color: str) -> str:
    def esc(part: str) -> str:
        out = part.replace("-", "--").replace("_", "__").replace(" ", "_")
        return quote(out, safe="_")
    return f"https://img.shields.io/badge/{esc(label)}-{esc(message)}-{color}"


def maintainer_review(root: Path, since_value: str, base: str | None = None, out_dir: str = "", with_pr_issues: bool = False) -> dict[str, Any]:
    """Capture-free maintainer review of a repo's recent commits (the wedge).

    Reuses the canonical RUBRIC underneath via MAINTAINER_PROFILE, so the human
    badge/report and a machine-aggregatable sidecar come from one classifier.
    """
    if base:
        resolved = base_since_value(root, base)
        since = parse_since(resolved) if resolved else parse_since(since_value)
    else:
        since = parse_since(since_value)
    commits = git_commit_files(root, since, base or "")
    pr_issue = gh_pr_issue_activity(root, since) if with_pr_issues else None
    classified = []
    maintainer_counts: Counter[str] = Counter()
    canonical_counts: Counter[str] = Counter()
    attestation: Counter[str] = Counter()
    authors: set[str] = set()
    human_authors: set[str] = set()
    for commit in commits:
        subject = str(commit.get("subject") or "")
        files = commit.get("files") or []
        result = classify_commit(subject, files, commit.get("file_weights"))
        name = str(commit.get("author_name") or "")
        tier = attestation_tier(
            name, str(commit.get("author_email") or ""),
            str(commit.get("signature") or ""), str(commit.get("signoff") or ""),
        )
        attestation[tier] += 1
        if name:
            authors.add(name)
            if tier != "bot":
                human_authors.add(name)
        maintainer_counts[result["label"]] += 1
        canonical_counts[result["canonical"]] += 1
        classified.append(
            {
                "commit": str(commit.get("commit") or "")[:12],
                "subject": subject,
                "files_changed": len(files),
                "label": result["label"],
                "canonical": result["canonical"],
                "reason": result["reason"],
                "author": name,
                "attestation": tier,
            }
        )
    total = sum(maintainer_counts.values()) or 1
    feature_pct = round(maintainer_counts.get("feature", 0) * 100 / total)
    upkeep_pct = round(sum(maintainer_counts.get(label, 0) for label in UPKEEP_LABELS) * 100 / total)
    bot_pct = round(attestation.get("bot", 0) * 100 / total)
    attested_pct = round(attestation.get("attested", 0) * 100 / total)
    human_pct = round(attestation.get("human", 0) * 100 / total)
    # The badge answers the maintainer's one question in a glance: advancing the
    # core vs upkeep. `other` is shown in the full report, not forced into upkeep.
    message = f"feature {feature_pct}% · upkeep {upkeep_pct}%" if commits else "no commits in window"
    # Neutral, fixed color: a badge must inform, never grade.
    badge = {"schemaVersion": 1, "label": "work", "message": message, "color": "blue"}
    badge_markdown = f"![StillMirror]({shields_badge_url('work', message, 'blue')})"

    target = Path(out_dir).expanduser() if out_dir else (sm_dir(root) / "reviews")
    target.mkdir(parents=True, exist_ok=True)
    report_path = target / f"{utc_now()[:10]}-maintainer-review.md"
    badge_path = target / "maintainer-badge.json"
    sidecar_path = target / "maintainer-review.json"

    lines = [
        "# StillMirror Maintainer Review",
        "",
        f"- Generated: {utc_now()}",
        f"- Window start: {since.isoformat().replace('+00:00', 'Z')}",
        f"- Commits analysed: {len(commits)}",
        "",
        "Evidence for the maintainer's own review, not a verdict. It reads only git",
        "commit subjects, changed files, and authorship.",
        "",
        "## Coverage & Blind Spots",
        "",
        "- Reads commit subjects only — it does NOT see pull-request or issue triage,",
        "  review discussion, or the effort/impact behind any commit.",
        "- `triage_responding` is undercounted: most of it lives in PR/issue threads",
        "  this git-only view cannot see.",
        "",
        "## Effort distribution",
        "",
    ]
    for label in MAINTAINER_PROFILE:
        count = maintainer_counts.get(label, 0)
        pct = round(count * 100 / total)
        lines.append(f"- `{label}`: {count} ({pct}%)")
    if with_pr_issues:
        lines.extend(["", "## Triage & responding (via gh)", ""])
        if pr_issue is not None:
            lines.append(f"- Merged PRs in window: {pr_issue['merged_prs']}")
            lines.append(f"- Closed issues in window: {pr_issue['closed_issues']}")
            lines.append(f"- Open PRs (backlog): {pr_issue['open_prs']}")
            lines.append(f"- Open issues (backlog): {pr_issue['open_issues']}")
            lines.append("- Partially fills the `triage_responding` blind spot above; thread")
            lines.append("  content and per-responder detail are out of scope (ranking risk).")
        else:
            lines.append("- `gh` unavailable or repo not on GitHub — `triage_responding` remains a git-only blind spot.")
    lines.extend(
        [
            "",
            f"For your own judgement: feature {feature_pct}% · upkeep {upkeep_pct}% "
            "(triage is undercounted — see Coverage).",
            "",
            "## Authorship & accountability",
            "",
            "Composition, not a contributor ranking. As agents make contributions cheap",
            "and abundant, the scarce signal is how much of this work carries a human's",
            "explicit accountability — a sign-off or a signature.",
            "",
            f"- Commits in window: {len(commits)}",
            f"- From bots: {attestation.get('bot', 0)} ({bot_pct}%)",
            f"- Human-attested (sign-off or signature): {attestation.get('attested', 0)} ({attested_pct}%)",
            f"- Human, no explicit attestation: {attestation.get('human', 0)} ({human_pct}%)",
            f"- Distinct authors: {len(authors)} ({len(human_authors)} human)",
            "",
            "_Signatures are detected, not cryptographically verified here. This is"
            " evidence about accountability coverage, not a judgment of any contributor._",
            "",
            "## Badge",
            "",
            "Paste into your README (regenerate periodically):",
            "",
            f"`{badge_markdown}`",
            "",
            "## Boundaries",
            "",
            "- No score or grade is produced; the badge color is neutral by design.",
            "- \"Maintenance-heavy\" would be an observation for your review, not a judgment.",
            "- Evidence, not verdict.",
            "",
        ]
    )
    report_path.write_text("\n".join(lines), encoding="utf-8")
    write_json(badge_path, badge)
    write_json(
        sidecar_path,
        {
            "schema_version": 1,
            "generated_at": utc_now(),
            "since": since.isoformat().replace("+00:00", "Z"),
            "commits": len(commits),
            "maintainer_counts": dict(maintainer_counts),
            "canonical_counts": dict(canonical_counts),
            "authorship": {
                "bot": attestation.get("bot", 0),
                "attested": attestation.get("attested", 0),
                "human": attestation.get("human", 0),
                "distinct_authors": len(authors),
                "distinct_human_authors": len(human_authors),
            },
            "pr_issue_activity": pr_issue if with_pr_issues else None,
            "coverage": {
                "source": "git commit subjects, changed files, and authorship",
                "not_captured": [
                    "Pull-request and issue triage / responding.",
                    "Review discussion and the effort or impact behind a commit.",
                    "Whether a detected signature is cryptographically valid.",
                ],
            },
            "entries": classified,
        },
    )
    return {
        "commits": len(commits),
        "maintainer_counts": dict(maintainer_counts),
        "canonical_counts": dict(canonical_counts),
        "authorship": dict(attestation),
        "badge_markdown": badge_markdown,
        "report": str(report_path),
        "badge": str(badge_path),
        "sidecar": str(sidecar_path),
    }


def _median(values: list[float]) -> float:
    if not values:
        return 0.0
    ordered = sorted(values)
    mid = len(ordered) // 2
    if len(ordered) % 2:
        return float(ordered[mid])
    return (ordered[mid - 1] + ordered[mid]) / 2.0


def collect_sidecars(paths: list[str]) -> list[Path]:
    found: list[Path] = []
    for raw in paths:
        path = Path(raw).expanduser()
        if path.is_dir():
            found.extend(sorted(path.rglob("maintainer-review.json")))
        elif path.is_file():
            found.append(path)
    return found


def aggregate_reviews(paths: list[str], out_dir: str = "") -> dict[str, Any]:
    """Anonymized aggregate over many maintainer-review sidecars.

    Names no project and no contributor — only distributions across repos. This
    is the only honest way to make a flood of repos legible without ranking or
    exposing anyone.
    """
    repos = []
    for path in collect_sidecars(paths):
        doc = load_json(path, None)
        if isinstance(doc, dict) and "maintainer_counts" in doc:
            repos.append(doc)
    per_repo = []
    label_totals: Counter[str] = Counter()
    tier_totals: Counter[str] = Counter()
    total_commits = 0
    for doc in repos:
        counts = doc.get("maintainer_counts") or {}
        commits = int(doc.get("commits") or sum(counts.values()) or 0)
        denom = commits or 1
        authorship = doc.get("authorship") or {}
        per_repo.append(
            {
                "feature": counts.get("feature", 0) * 100 / denom,
                "upkeep": sum(counts.get(label, 0) for label in UPKEEP_LABELS) * 100 / denom,
                "bot": authorship.get("bot", 0) * 100 / denom,
                "attested": authorship.get("attested", 0) * 100 / denom,
            }
        )
        for label, value in counts.items():
            label_totals[label] += value
        for tier in ("bot", "attested", "human"):
            tier_totals[tier] += authorship.get(tier, 0)
        total_commits += commits
    medians = {
        "feature_pct": round(_median([r["feature"] for r in per_repo])),
        "upkeep_pct": round(_median([r["upkeep"] for r in per_repo])),
        "bot_pct": round(_median([r["bot"] for r in per_repo])),
        "attested_pct": round(_median([r["attested"] for r in per_repo])),
    }
    aggregate = {
        "schema_version": 1,
        "generated_at": utc_now(),
        "anonymized": True,
        "repos": len(repos),
        "total_commits": total_commits,
        "median_pct": medians,
        "label_totals": dict(label_totals),
        "attestation_totals": dict(tier_totals),
    }
    target = Path(out_dir).expanduser() if out_dir else Path.cwd()
    target.mkdir(parents=True, exist_ok=True)
    json_path = target / "state-of-oss-maintenance.json"
    report_path = target / "state-of-oss-maintenance.md"
    write_json(json_path, aggregate)
    report_path.write_text(
        "\n".join(
            [
                "# State of OSS Maintenance (anonymized aggregate)",
                "",
                f"- Generated: {utc_now()}",
                f"- Repositories: {len(repos)}",
                f"- Total commits: {total_commits}",
                "",
                "This aggregate names no project and no contributor — only distributions.",
                "",
                "## Effort (median across repos)",
                "",
                f"- feature: {medians['feature_pct']}%",
                f"- upkeep: {medians['upkeep_pct']}%",
                "",
                "## Accountability (median across repos)",
                "",
                f"- bot-authored: {medians['bot_pct']}%",
                f"- human-attested: {medians['attested_pct']}%",
                "",
                "## Boundaries",
                "",
                "- Anonymized; evidence about the ecosystem, not a ranking of projects.",
                "- No project or contributor is named.",
                "",
            ]
        ),
        encoding="utf-8",
    )
    return {
        "repos": len(repos),
        "total_commits": total_commits,
        "median_pct": medians,
        "report": str(report_path),
        "json": str(json_path),
    }


def main() -> int:
    parser = argparse.ArgumentParser(description="StillMirror Review local helper")
    sub = parser.add_subparsers(dest="command")
    sub.add_parser("init")
    ledger = sub.add_parser("ledger")
    ledger.add_argument("--since", default="30d")
    ledger.add_argument("--base", default="", help="scope to commits since merge-base(<ref>, HEAD)")
    review = sub.add_parser("review")
    review.add_argument("--since", default="30d")
    review.add_argument("--base", default="", help="scope to commits since merge-base(<ref>, HEAD)")
    review_due = sub.add_parser("review-due")
    review_due.add_argument("--threshold", type=int, default=None)
    review_due.add_argument("--nudge", action="store_true", help="SessionStart hook mode: emit a quiet line only if opted in and due")
    maintainer = sub.add_parser("maintainer-review")
    maintainer.add_argument("--since", default="90d")
    maintainer.add_argument("--base", default="", help="scope to commits since merge-base(<ref>, HEAD)")
    maintainer.add_argument("--out-dir", default="", help="where to write report + badge (default .stillmirror/reviews; point at a committed dir to publish the badge)")
    maintainer.add_argument("--with-pr-issues", action="store_true", help="opt-in: enrich with merged-PR / closed-issue counts via gh (degrades gracefully)")
    aggregate = sub.add_parser("aggregate")
    aggregate.add_argument("paths", nargs="+", help="maintainer-review.json sidecars or directories of them")
    aggregate.add_argument("--out-dir", default="")
    goals = sub.add_parser("goals")
    goals_sub = goals.add_subparsers(dest="goals_command")
    goals_add = goals_sub.add_parser("add")
    goals_add.add_argument("statement")
    goals_add.add_argument("--source", default="user")
    goals_add.add_argument("--scope", default="project")
    goals_add.add_argument("--review-state", default="accepted", choices=["reviewed", "accepted"])
    goals_sub.add_parser("list")
    goals_sub.add_parser("events")
    goals_retire = goals_sub.add_parser("retire")
    goals_retire.add_argument("goal")
    goals_retire.add_argument("--note", default="")
    goals_replace = goals_sub.add_parser("replace")
    goals_replace.add_argument("goal")
    goals_replace.add_argument("--with", dest="new_statement", required=True)
    goals_replace.add_argument("--source", default="user")
    goals_replace.add_argument("--scope", default="project")
    goals_replace.add_argument("--review-state", default="accepted", choices=["reviewed", "accepted"])
    goals_replace.add_argument("--note", default="")
    problem = sub.add_parser("problem")
    problem_sub = problem.add_subparsers(dest="problem_command")
    problem_set = problem_sub.add_parser("set")
    problem_set.add_argument("statement")
    problem_set.add_argument("--confidence", type=float, default=0.5)
    problem_set.add_argument("--alternative", action="append", default=[], dest="alternatives")
    correct = sub.add_parser("correct")
    correct.add_argument("--event", required=True)
    correct.add_argument("--label", action="append", required=True, choices=list(RUBRIC.keys()))
    correct.add_argument("--note", default="")
    alignment = sub.add_parser("alignment")
    alignment_sub = alignment.add_subparsers(dest="alignment_command")
    alignment_record = alignment_sub.add_parser("record")
    alignment_record.add_argument("--label", action="append", required=True, choices=sorted(ALIGNMENT_LABELS))
    alignment_record.add_argument("--note", default="")
    alignment_record.add_argument("--review-file", default="")
    alignment_record.add_argument("--attested-by", default="", help="name of the human standing behind this review (defaults to git user.name)")
    alignment_sub.add_parser("list")
    args = parser.parse_args()
    root = project_root()
    if args.command == "init":
        init_project(root)
    elif args.command == "ledger":
        result = build_ledger(root, args.since, args.base or None)
        print(json.dumps({"entry_count": result["entry_count"], "output": str(sm_dir(root) / "allocations" / "allocation-ledger.json")}, ensure_ascii=False, indent=2))
    elif args.command == "review":
        output = render_review(root, args.since, args.base or None)
        print(json.dumps({"output": str(output)}, ensure_ascii=False, indent=2))
    elif args.command == "review-due":
        threshold = nudge_threshold(args.threshold)
        if args.nudge:
            return run_nudge(threshold)
        print(json.dumps(compute_review_due(root, threshold), ensure_ascii=False, indent=2))
    elif args.command == "maintainer-review":
        result = maintainer_review(root, args.since, args.base or None, args.out_dir, args.with_pr_issues)
        print(json.dumps(result, ensure_ascii=False, indent=2))
    elif args.command == "aggregate":
        result = aggregate_reviews(args.paths, args.out_dir)
        print(json.dumps(result, ensure_ascii=False, indent=2))
    elif args.command == "goals":
        if args.goals_command == "add":
            goal = add_goal(root, args.statement, args.source, args.scope, args.review_state)
            print(json.dumps({"goal": goal, "output": str(accepted_goals_path(root))}, ensure_ascii=False, indent=2))
        elif args.goals_command == "list":
            print(json.dumps(list_goals(root), ensure_ascii=False, indent=2))
        elif args.goals_command == "events":
            print(json.dumps({"events": list_goal_events(root)}, ensure_ascii=False, indent=2))
        elif args.goals_command == "retire":
            goal = retire_goal(root, args.goal, args.note)
            print(json.dumps({"retired": goal, "output": str(goal_events_path(root))}, ensure_ascii=False, indent=2))
        elif args.goals_command == "replace":
            result = replace_goal(root, args.goal, args.new_statement, args.source, args.scope, args.review_state, args.note)
            print(json.dumps({"replaced": result, "output": str(goal_events_path(root))}, ensure_ascii=False, indent=2))
        else:
            goals.print_help()
            return 2
    elif args.command == "problem":
        if args.problem_command == "set":
            doc = set_problem(root, args.statement, args.confidence, args.alternatives)
            print(json.dumps({"problem": doc, "output": str(sm_dir(root) / "problems" / "mainline-hypothesis.json")}, ensure_ascii=False, indent=2))
        else:
            problem.print_help()
            return 2
    elif args.command == "correct":
        record = record_correction(root, args.event, args.label, args.note)
        print(json.dumps({"correction": record, "output": str(corrections_path(root))}, ensure_ascii=False, indent=2))
    elif args.command == "alignment":
        if args.alignment_command == "record":
            record = record_alignment(root, args.label, args.note, args.review_file, args.attested_by)
            print(json.dumps({"record": record, "output": str(alignment_path(root))}, ensure_ascii=False, indent=2))
        elif args.alignment_command == "list":
            print(json.dumps({"records": list_alignment(root)}, ensure_ascii=False, indent=2))
        else:
            alignment.print_help()
            return 2
    else:
        parser.print_help()
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
