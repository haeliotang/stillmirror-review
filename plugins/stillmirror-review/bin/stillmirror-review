# Conventional-commit type -> maintainer label (takes priority over keywords).
CONVENTIONAL_COMMIT = {
    "feat": "feature",
    "fix": "bug_fixing",
    "perf": "bug_fixing",
    "refactor": "bug_fixing",
    "docs": "docs",
    "test": "infra",
